# Resend API key — https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Webhook secret from Supabase → Authentication → Hooks (click "Generate Secret")
# Keep the full "v1,whsec_..." prefix — the function strips it internally.
SEND_EMAIL_HOOK_SECRET=v1,whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Sender address shown to recipients. Domain must be verified in Resend.
EMAIL_FROM=ComparaCasa <noreply@yourdomain.com>
