# Supabase — copy to .env.local and fill in your project values
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Email auth (sign up / sign in) works out of the box once the keys above are
# set. Confirmation links point at <site>/auth/confirm — make sure your
# Supabase project's Site URL / Redirect URLs include this app's origin.

# SEO (optional)
# Canonical site origin used for metadata, sitemap.xml and robots.txt. On Vercel
# this is auto-detected; set it explicitly for a custom domain (no trailing slash).
NEXT_PUBLIC_SITE_URL=https://comparacasa.app
# Google Search Console verification token (the content of the meta tag).
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
